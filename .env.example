# Optional. The pipeline works WITHOUT this — it falls back to the local `claude`
# CLI (headless, uses your Claude Code login). Setting a key makes each
# per-document model call go through the Anthropic API instead: ~10x faster and
# fully deterministic, which speeds up the verify→retry loop.
#
# Copy this file to `.env` and paste your key. `.env` is gitignored.
ANTHROPIC_API_KEY=

# Optional overrides:
# INDEXER_MODEL=claude-opus-4-8

# --- Config-authoring agent (schema_agent.py) messaging channels ---
# All optional. The CONSOLE channel works offline with no creds.
# Discord (two-way via REST + polling): create a bot, enable the MESSAGE CONTENT
# INTENT, invite it with View Channel / Send Messages / Read Message History.
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_POLL_INTERVAL=2
# INDEXER_CHANNEL=console            # default channel when --channel is omitted
# SCHEMA_AGENT_MAX_RETRIES=3
# CHANNEL_TIMEOUT=0                  # seconds to wait for a reply (0 = wait forever)
#
# WhatsApp (STRETCH — requires `pip install twilio flask` + a public webhook):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# TWILIO_WHATSAPP_TO=
